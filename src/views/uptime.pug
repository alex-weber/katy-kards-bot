extends layout

block content
  div.container

    .page-hero
      h2.page-title= title
      p.page-subtitle Service availability over recent windows.
    div.uptime-grid
      each lastDays, label in stats.statistics.uptime
        - let days = parseInt(label.replace('l', ''))
        - let daysOutput = days === 1 ? 'Last Day' : 'Last ' + days + ' days'
        each ratio, index in lastDays
          - let percentage = Math.floor(ratio)
          if index === 'ratio'
              div.stat-card.uptime-card
                .stat-label= daysOutput
                .stat-value= percentage + '%'
                div.progress.uptime-progress(role="progressbar" aria-label=daysOutput aria-valuenow=percentage aria-valuemin="0" aria-valuemax="100")
                  div.progress-bar.bg-success(style=`width: ${percentage}%`)= percentage + '%'





