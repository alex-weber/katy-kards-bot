extends layout

block content
    .page-hero
        h2.page-title= title
        p.page-subtitle Securely completing Discord authentication.
    .content-panel.auth-panel
        .panel-header
            .panel-title-group
                span.panel-icon(aria-hidden="true")
                    svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                        path(d="M20 13c0 5-3.5 7.5-7.7 8.9a1 1 0 0 1-.6 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.2-2.6a1.3 1.3 0 0 1 1.6 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z")
                        path(d="M9 12l2 2 4-4")
                h3.panel-title Login Info
        div#login.panel-body
            p.text-secondary.mb-0 Login Info
        div#info.panel-body
    script(src="/static/auth.js" type="text/javascript")
