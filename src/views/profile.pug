extends layout

block content
    -
        function profileHistoryTime(message) {
            const rawDate = message.timestamp || message.createdAt
            const date = new Date(rawDate)
            if (Number.isNaN(date.getTime())) {
                return String(message.createdAt || '').replace(/\s+[A-Z]{2,5}$/, '')
            }
            const today = new Date()
            const yesterday = new Date()
            yesterday.setDate(today.getDate() - 1)
            const sameDay = (a, b) => a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate()
            const dayLabel = sameDay(date, today)
                ? 'Today'
                : sameDay(date, yesterday)
                    ? 'Yesterday'
                    : new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' }).format(date)
            const time = new Intl.DateTimeFormat('en-GB', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false,
            }).format(date)
            return dayLabel + ', ' + time
        }

    .page-hero
        h2.page-title= title
        p.page-subtitle Command activity and account overview.

    .profile-panel
        .profile-avatar
            div
                if avatarUrl
                    img(src=avatarUrl, alt="No avatar")
                else
                    span #{(displayName || '?').charAt(0).toUpperCase()}
        .profile-body
            h3.profile-name #{displayName}
            .profile-stat-grid
                .stat-card
                    .stat-label Total messages
                    .stat-value #{stats.total}
                .stat-card
                    .stat-label Last 30 days
                    .stat-value #{stats.lastMonth}
                .stat-card
                    .stat-label Last 24 hours
                    .stat-value #{stats.lastDay}


    if isOwn && history
        .content-panel.mt-4
            .panel-header
                .panel-title-group
                    span.panel-icon(aria-hidden="true")
                        svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                            path(d="M4 7h16")
                            path(d="M4 12h12")
                            path(d="M4 17h8")
                    h3.panel-title Last 24 Hours Commands
            .data-table-wrap.data-table-wrap-compact
                table.data-table
                    thead
                        tr
                            th(scope='col') Command
                            th(scope='col') Time
                    tbody
                        each message in history
                            tr
                                td.break-all #{message.content}
                                td.data-muted #{profileHistoryTime(message)}


    p &nbsp;
    p &nbsp;
