extends layout

block content
  div.container
    // Page Title
    h3.text-center.text-primary.mt-4.mb-5 Dashboard

    // Compact stat widgets
    div.mini-stats.mb-5
      div.mini-stat-card.panel-accent-blue
        div.panel-header
          div.panel-title-group
            span.panel-icon(aria-hidden="true")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z")
            h4.panel-title Messages
        div.mini-stat-row
          div.mini-stat-item
            span.mini-stat-label Today
            span.mini-stat-value#messagesDaily —
          div.mini-stat-item
            span.mini-stat-label Last 30 days
            span.mini-stat-value#messages30d —
          div.mini-stat-item
            span.mini-stat-label Total
            span.mini-stat-value#messagesTotal —
      div.mini-stat-card.panel-accent-amber
        div.panel-header
          div.panel-title-group
            span.panel-icon(aria-hidden="true")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                polyline(points="4 17 10 11 4 5")
                line(x1="12" y1="19" x2="20" y2="19")
            h4.panel-title Screenshot commands
        div.mini-stat-row
          div.mini-stat-item
            span.mini-stat-label Today
            span.mini-stat-value#screenshotCmdDaily —
          div.mini-stat-item
            span.mini-stat-label Last 30 days
            span.mini-stat-value#screenshotCmd30d —
          div.mini-stat-item
            span.mini-stat-label Total
            span.mini-stat-value#screenshotCmdTotal —
      div.mini-stat-card.panel-accent-teal
        div.panel-header
          div.panel-title-group
            span.panel-icon(aria-hidden="true")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z")
                circle(cx="12" cy="13" r="4")
            h4.panel-title Screenshots taken
        div.mini-stat-row
          div.mini-stat-item
            span.mini-stat-label Today
            span.mini-stat-value#screenshotsToday —
          div.mini-stat-item
            span.mini-stat-label Last 30 days
            span.mini-stat-value#screenshots30d —
          div.mini-stat-item
            span.mini-stat-label Total
            span.mini-stat-value#screenshotsTotal —

    include includes/datepicker.pug

    // Chart Section for Messages
    div
      // Loading Spinner for Messages Chart
      div#loadingSpinner.d-flex.justify-content-center.align-items-center(style="height: 300px; display: flex;")
        div.spinner-border.text-primary(role="status")
      // Canvas for Messages Chart
      canvas#messagesChart(style="height: 300px; width: 100%; display: none;")

    div.dashboard-leaderboards
      section.leaderboard-panel.panel-accent-teal
        div.panel-header
          div.panel-title-group
            span.panel-icon(aria-hidden="true")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M4 7h16")
                path(d="M4 12h10")
                path(d="M4 17h7")
            h4.panel-title Top 100 Commands
          span.panel-kicker Live ranking
        div.leaderboard-table-wrap
          table.leaderboard-table
            thead
              tr
                th.leaderboard-rank-col(scope='col') #
                th(scope='col') Command
                th.leaderboard-count-col(scope='col') Count
            tbody#topMessages

      section.leaderboard-panel.panel-accent-amber
        div.panel-header
          div.panel-title-group
            span.panel-icon(aria-hidden="true")
              svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2")
                circle(cx="9" cy="7" r="4")
                path(d="M22 21v-2a4 4 0 0 0-3-3.87")
                path(d="M16 3.13a4 4 0 0 1 0 7.75")
            h4.panel-title Top 100 Users
          span.panel-kicker Most active
        div.leaderboard-table-wrap
          table.leaderboard-table
            thead
              tr
                th.leaderboard-rank-col(scope='col') #
                th(scope='col') User
                th.leaderboard-rank-col(scope='col') All-Time
                th.leaderboard-count-col(scope='col') Commands
            tbody#topUsers
  .my-5
  p &nbsp;
  p &nbsp;

  script(src="/static/vendor/chart.js")
  script(src="/static/dashboard.js")

