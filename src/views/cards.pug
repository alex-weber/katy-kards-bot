extends layout

block content
    div.container
        .page-hero
            h2.page-title Cards by Factions
                span#factionsTotalCardsCount
            p.page-subtitle Card distribution across every faction in the database.

        .cards-faction-grid
            .content-panel.chart-panel
                .panel-header
                    .panel-title-group
                        span.panel-icon(aria-hidden="true")
                            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M21 12a9 9 0 1 1-9-9v9z")
                                path(d="M12 3a9 9 0 0 1 9 9h-9z")
                        h3.panel-title Faction Overview
                .chart-shell.chart-shell-factions
                    div#loadingSpinnerFactions.d-flex.justify-content-center.align-items-center.h-100
                        div.spinner-border.text-primary(role="status")
                    canvas#factionsChart(style="display: none;")

            .cards-faction-tables
              .content-panel
                .panel-header
                    .panel-title-group
                        span.panel-icon(aria-hidden="true")
                            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M8 6h13")
                                path(d="M8 12h13")
                                path(d="M8 18h13")
                                path(d="M3 6h.01")
                                path(d="M3 12h.01")
                                path(d="M3 18h.01")
                        h3.panel-title Main Nations
                .faction-table-shell
                    table.data-table.faction-table
                        thead
                            tr
                                th(scope="col") Faction
                                th(scope="col") Cards
                                th(scope="col") Share
                        tbody#mainFactionsTable
              .content-panel
                .panel-header
                    .panel-title-group
                        span.panel-icon(aria-hidden="true")
                            svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                                path(d="M8 6h13")
                                path(d="M8 12h13")
                                path(d="M8 18h13")
                                path(d="M3 6h.01")
                                path(d="M3 12h.01")
                                path(d="M3 18h.01")
                        h3.panel-title Ally Nations
                .faction-table-shell
                    table.data-table.faction-table
                        thead
                            tr
                                th(scope="col") Faction
                                th(scope="col") Cards
                                th(scope="col") Share
                        tbody#allyFactionsTable
        p &nbsp;
        p &nbsp;
        script(src="/static/vendor/chart.js")
        script.
            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;')
            }

            function textColorForBackground(hex) {
                const clean = hex.replace('#', '')
                const r = parseInt(clean.substring(0, 2), 16)
                const g = parseInt(clean.substring(2, 4), 16)
                const b = parseInt(clean.substring(4, 6), 16)
                const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255
                return luminance > 0.58 ? '#111418' : '#f8f9fa'
            }

            function formatPercent(count, total) {
                if (!total) return '0%'
                return ((count / total) * 100).toFixed(1) + '%'
            }

            function factionLabel(faction) {
                const labels = {
                    germany: 'GERMANY',
                    usa: 'USA',
                    britain: 'BRITAIN',
                    soviet: 'SOVIET UNION',
                    japan: 'JAPAN',
                    france: 'FRANCE',
                    italy: 'ITALY',
                    poland: 'POLAND',
                    finland: 'FINLAND',
                    anzac: 'ANZAC',
                    neutral: 'NEUTRAL',
                }
                return labels[faction] || faction
                    .split(/[\s_-]+/)
                    .map(word => word.toUpperCase())
                    .join(' ')
            }

            function renderFactionsTable(tableId, items, colorByFaction, total) {
                const table = document.getElementById(tableId)
                table.innerHTML = items.map(item => {
                    const color = colorByFaction[item.faction] || '#343a40'
                    return `
                        <tr>
                            <td>
                                <span class="faction-chip" style="background: ${color}; color: ${textColorForBackground(color)}">
                                    ${escapeHtml(factionLabel(item.faction))}
                                </span>
                            </td>
                            <td class="data-strong">${Number(item.count || 0).toLocaleString()}</td>
                            <td>${formatPercent(item.count, total)}</td>
                        </tr>
                    `
                }).join('')
            }

            async function render() {
                let cards = await fetch('/api/cards-by-faction')
                cards = await cards.json()
                renderFactionsChart(cards)
            }
            function renderFactionsChart(apiData) {
                const loadingSpinner = document.getElementById('loadingSpinnerFactions')
                const chartCanvas = document.getElementById('factionsChart')
                const totalCardsCountElement = document.getElementById('factionsTotalCardsCount')

                const sortedData = [...apiData.data].sort((a, b) => b.count - a.count)
                const labels = sortedData.map(item => factionLabel(item.faction))
                const data = sortedData.map(item => item.count)
                const totalCount = data.reduce((sum, count) => sum + count, 0)
                totalCardsCountElement.innerText = ' (' + totalCount + ')'
                // Hide loading spinner and show canvas
                loadingSpinner.classList.add('d-none')
                chartCanvas.style.display = 'block'

                // Define faction colors
                const baseColors = {
                    soviet: '#604F3D',
                    usa: '#63694C',
                    japan: '#9D7C41',
                    germany: '#5E6965',
                    britain: '#928F7C',
                    france: '#4C566F',
                    italy: '#626260',
                    poland: '#645E4B',
                    finland: '#B8B8A0',
                    anzac: '#7A5727',
                    neutral: '#0c0c0c',
                }
                const mainNationOrder = ['germany', 'usa', 'britain', 'soviet', 'japan']
                const mainNations = new Set(mainNationOrder)

                // Generate background gradients
                const backgroundColors = sortedData.map(faction => {
                    return baseColors[faction.faction] || '#343a40'
                })
                const colorByFaction = sortedData.reduce((result, item) => {
                    result[item.faction] = baseColors[item.faction] || '#343a40'
                    return result
                }, {})
                renderFactionsTable(
                    'mainFactionsTable',
                    sortedData.filter(item => mainNations.has(item.faction)),
                    colorByFaction,
                    totalCount
                )
                renderFactionsTable(
                    'allyFactionsTable',
                    sortedData.filter(item => !mainNations.has(item.faction)),
                    colorByFaction,
                    totalCount
                )

                // Pie chart configuration
                const config = {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: backgroundColors,
                            borderColor: '#171a1f',
                            borderWidth: 2,
                            hoverOffset: 10,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'right',
                                labels: {
                                    color: '#dee2e6',
                                    boxWidth: 14,
                                    boxHeight: 14,
                                    padding: 14,
                                },
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        const label = context.label || ''
                                        const value = context.raw || 0
                                        return `${label}: ${value} cards (${formatPercent(value, totalCount)})`
                                    }
                                }
                            }
                        },
                    }
                }


                const ctx = chartCanvas.getContext('2d')
                new Chart(ctx, config)

            }

            render()
