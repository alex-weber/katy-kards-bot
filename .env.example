DATABASE_URL="postgres://USER:PASSWORD@localhost:5432/URL?schema=public"
DISCORD_TOKEN="YOUR_TOKEN"
DISCORD_CLIENT_ID="YOUR_CLIENT_ID"
DISCORD_AUTH_URL="URL_FOR_AUTH"
TELEGRAM_TOKEN="YOUR_TOKEN"
REDISCLOUD_URL="URL_TO_REDIS_SERVER"
IMG_UPLOAD_API_KEY="key"
#WEB
SESSION_SECRET="Very secret"
# 30 days
COOKIE_MAX_AGE="2592000000"
# 15 minutes
WEB_RATE_LIMIT_WINDOW_MS=900000
# requests per rate limit window
WEB_RATE_LIMIT_MAX=300
#BROWSERLESS
BROWSERLESS_API_KEY="YOUR_KEY"
BROWSERLESS_HOST="production-ams.browserless.io"
SCREENSHOT_TIMEOUT=30
#VARIABLES
STATS_DIVIDER=500

# historical (<= yesterday) stats cache, 1 day - immutable, only bounds memory
CACHE_HISTORICAL_EXPIRE=86400
# Memory chart keeps the latest N process memory samples. 12 hours
MEMORY_USAGE_SAMPLE_LIMIT=60
# Memory sampling interval in minutes.
MEMORY_USAGE_SAMPLE_INTERVAL_MINUTES=10
# Default RSS warning threshold in MB. GOD users can override this from /system.
MEMORY_USAGE_THRESHOLD_MB=512
# Runtime RSS limit line in MB.
MEMORY_AVAILABLE_MB=562
# Redis memory available in MB.
REDIS_MEMORY_AVAILABLE_MB=30
# Warn when a memory metric increases by this many MB between two samples.
MEMORY_USAGE_JUMP_THRESHOLD_MB=64

SYNC_BATCH_SIZE=5
# bot message requirements
LIMIT=5
MIN_STR_LEN=2
MAX_STR_LEN=4000
SLOW_MODE_INTERVAL=5000

# CACHE EXPIRATION (in seconds)
# 30 days
REDIS_EXP_DECK=2592000
# 30 days
REDIS_EXP_SYNONYM=2592000
# 90 days
REDIS_EXP_SEARCH=7776000
# 7 days
REDIS_EXP_USER=604800
# 1 hour
REDIS_EXP_PERMISSION=3600
# 10 minutes
REDIS_EXP_PAGINATION=600
# 90 days
REDIS_EXP_TELEGRAM=7776000
# 5 minutes
REDIS_EXP_PROFILE=300
CACHE_PAGE_EXPIRE=300
CACHE_API_EXPIRE=300
